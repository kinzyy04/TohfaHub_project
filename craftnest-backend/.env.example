# Application Settings
PROJECT_NAME="CraftNest API"
ENVIRONMENT="development"
DEBUG=true

# Security
SECRET_KEY="your-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Settings
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/craftnest"
TEST_DATABASE_URL="postgresql+psycopg://craftnest_app:[same-password]@127.0.0.1:5432/craftnest_test"

# Operations / Backups
# BACKUP_LOCAL_DIR="D:\craftnest_backups" # Path to external SSD
# BACKUP_GPG_PASSPHRASE="your-super-secure-passphrase-to-encrypt-cloud-backups"

